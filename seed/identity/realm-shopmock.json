{
  "realm": "shopmock",
  "enabled": true,
  "displayName": "ShopMock",
  "sslRequired": "none",
  "registrationAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "customer",
        "description": "Storefront customer"
      },
      {
        "name": "seller",
        "description": "Marketplace seller (Tier 2)"
      },
      {
        "name": "employee",
        "description": "Internal staff (HR/Finance/Legal/IT)"
      },
      {
        "name": "global-admin",
        "description": "Tier 0 global administrator"
      }
    ]
  },
  "groups": [
    {
      "name": "customers",
      "realmRoles": [
        "customer"
      ]
    },
    {
      "name": "sellers",
      "realmRoles": [
        "seller"
      ]
    },
    {
      "name": "staff",
      "realmRoles": [
        "employee"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "storefront",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost/*"
      ],
      "webOrigins": [
        "http://localhost",
        "+"
      ],
      "protocolMappers": [
        {
          "name": "pgrst-role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "role",
            "claim.value": "customer",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "seller-dashboard",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost/seller/*",
        "http://localhost/silent-check-sso.html"
      ],
      "webOrigins": [
        "http://localhost",
        "+"
      ],
      "protocolMappers": [
        {
          "name": "pgrst-role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "role",
            "claim.value": "seller",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "internal-services",
      "enabled": true,
      "publicClient": false,
      "secret": "lab-internal-client-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false
    }
  ],
