# ShopMock lab secrets — FAKE values for a local attack-lab. Do not reuse anywhere.
# Copy to .env:  cp .env.example .env

# Postgres superuser (all four DBs share this lab password)
PG_SUPERUSER_PASSWORD=shopmock_pg_super

# OpenSearch (search service) admin
OPENSEARCH_ADMIN_PASSWORD=ShopMockAdmin123!

# Keycloak (identity) bootstrap admin — reach via bastion only
KC_ADMIN_USER=kcadmin
KC_ADMIN_PASSWORD=ChangeMe-KC!

# Vault dev-mode root token
VAULT_ROOT_TOKEN=lab-root-token

# Bastion / jump host login
BASTION_USER=jump
BASTION_PASSWORD=ChangeMe-Bastion!

# PostgREST JWT verification — RS256 public JWK matching the realm signing key in
# seed/identity/realm-shopmock.json. Order/Checkout/Customer services verify Keycloak
# tokens against this. No kid, so it validates whatever kid Keycloak stamps.
PGRST_JWT_SECRET='{"kty":"RSA","alg":"RS256","use":"sig","n":"vNZGiVQZQXTDax0-_8QMfypl8vB-ox18g_KL2hGGcJpx3Dj1mCDkuE_lMcy67rwkkWvESBNQXOJtKMAd1T8FDNMIKTlGXvVEaiCagpxkpehS2-pQiLIO1Wgez7GVy3mOgds-IysWrwEZOeb_VuOOx6buZOgeOyozeG9EWlABPWXxwku1ES0T3iwF92cyqOdCViztSdaYa8po1EJ0qeTPKly2oZsOFE41_UDB2W1_fNGc9PbXpBIneXzp1vZezhqpV8wtD62OujRLquY_cpmyOFrru1K33qhvlUR5h7TM3vvr-uZAamZdHV5o2ntofXdbzn-o7-exAqxM_fiVvZOfzw","e":"AQAB"}'

# internal-service-backend (Django) — signing key + its dedicated Postgres role
DJANGO_SECRET_KEY=change-me-django-secret
INTERNAL_BACKEND_DB_PASSWORD=change-me-internal-backend-pw
