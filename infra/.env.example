# ShopMock lab secrets — FAKE values for a local attack-lab. Do not reuse anywhere.
# Copy to .env:  cp .env.example .env

# Postgres superuser (all four DBs share this lab password)
PG_SUPERUSER_PASSWORD=shopmock_pg_super

# OpenSearch (search service) admin
OPENSEARCH_ADMIN_PASSWORD=ShopMockAdmin123!

# Keycloak (identity) bootstrap admin — reach via bastion only
KC_ADMIN_USER=kcadmin
KC_ADMIN_PASSWORD=ChangeMe-KC!

# Vault dev-mode root token
VAULT_ROOT_TOKEN=lab-root-token

# Bastion / jump host login
BASTION_USER=jump
BASTION_PASSWORD=ChangeMe-Bastion!
